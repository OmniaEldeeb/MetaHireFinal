# ── API ─────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://YOUR_NGROK_OR_DOMAIN/api

# ── Google Sign-In (use the WEB client id) ──────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Laravel Reverb (Pusher-protocol compatible) ─────
# Get these from your Laravel backend .env (REVERB_APP_KEY, REVERB_HOST).
# Port is typically 443 in production/ngrok; use 8080 for local dev.
# Scheme must be "https" when using ngrok or any TLS tunnel.
NEXT_PUBLIC_REVERB_APP_KEY=myapp-key
NEXT_PUBLIC_REVERB_HOST=your-reverb-host.example.com
NEXT_PUBLIC_REVERB_PORT=443
NEXT_PUBLIC_REVERB_SCHEME=https
